# Optional development diagnostics. No credentials are required by default.
OPENWHISPR_LOG_LEVEL=info

# Optional live OpenAI-compatible STT smoke test.
LOCALSCRIBE_STT_BASE_URL=
LOCALSCRIBE_STT_MODEL=whisper-1
LOCALSCRIBE_STT_API_KEY=

# Optional channel isolation for local development.
OPENWHISPR_CHANNEL=development
